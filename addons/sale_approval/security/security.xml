<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Sales Manager: barini ko'ra oladi va tasdiqlaydi -->
        <record id="rule_approval_manager_all" model="ir.rule">
            <field name="name">Approval: Manager - Barchani ko'radi</field>
            <field name="model_id" ref="model_sale_approval_request"/>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <!-- Sales User: faqat o'zini ko'radi -->
        <record id="rule_approval_salesman_own" model="ir.rule">
            <field name="name">Approval: Salesman - Faqat o'ziniki</field>
            <field name="model_id" ref="model_sale_approval_request"/>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
            <field name="domain_force">[('requested_by', '=', user.id)]</field>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>
    </data>
</odoo>
