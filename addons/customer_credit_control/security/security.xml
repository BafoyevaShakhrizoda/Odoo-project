<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="rule_credit_limit_manager" model="ir.rule">
            <field name="name">Credit Limit: Accounting Manager - To'liq huquq</field>
            <field name="model_id" ref="model_customer_credit_limit"/>
            <field name="groups" eval="[(4, ref('account.group_account_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <record id="rule_credit_limit_sales" model="ir.rule">
            <field name="name">Credit Limit: Sales - Faqat o'qish</field>
            <field name="model_id" ref="model_customer_credit_limit"/>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>
    </data>
</odoo>
